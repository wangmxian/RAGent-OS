# ===== 聊天模型（OpenAI 兼容 / vLLM） =====
OPENAI_BASE_URL=http://10.1.101.65:8001/v1
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=Qwen3.6-27B-FP8

# 备用：阿里云 DashScope
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_MODEL=qwen-flash-2025-07-28

# ===== 向量模型（OpenAI 兼容 embeddings） =====
EMBEDDING_BASE_URL=http://10.1.101.65:8002/v1
EMBEDDING_API_KEY=EMPTY
EMBEDDING_MODEL=qwen3-vl-embedding-8b
# 一次最多发送多少条文本片段
EMBEDDING_BATCH_SIZE=10

# ===== 数据持久化 =====
# SQLite 元数据库路径
DATA_DIR=./data
SQLITE_PATH=./data/app.db
# LanceDB 向量库目录
LANCEDB_PATH=./data/lancedb
# 上传文件原始存放目录
UPLOAD_DIR=./data/uploads

# ===== RuoYi RAG MCP HTTP 工具网关 =====
# 后端接口形如：{RAG_MCP_BASE_URL}/mcp/rag/tools/<tool-path>
RAG_MCP_BASE_URL=http://10.1.101.65:8080
# 如后端开启登录鉴权，填登录后 token；请求时会发送 Authorization: Bearer <token>
RAG_MCP_AUTH_TOKEN=
# 首次启动时自动写入默认 MCP 服务配置；设为 false 可关闭
RAG_MCP_AUTO_SEED=true
RAG_MCP_ENABLED=true
